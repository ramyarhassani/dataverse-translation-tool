      "name": "Ramyar Hassani",
      "url": "https://github.com/ramyarhassani"
    }
  ],
  "homepage": "https://github.com/ramyarhassani/pptb-dataverse-translation-tool#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ramyarhassani/pptb-dataverse-translation-tool.git"
  },
  "bugs": {
    "url": "https://github.com/ramyarhassani/pptb-dataverse-translation-tool/issues"
  },
  "keywords": [
    "powerplatform",
    "dataverse",
    "toolbox",
    "translation",
    "localization",
    "dynamics-365"
  ],
  "features": {
    "minAPI": "1.2.0"
  },
  "configurations": {
    "repository": "https://github.com/ramyarhassani/pptb-dataverse-translation-tool",
